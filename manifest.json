{
  "manifest_version": 3,
  "name": "PH-Job-Scraper",
  "version": "0.1.0",
  "description": "Collect job listings and export them as CSV or Excel.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.bdjobs.com/*",
    "*://*.wellfound.com/*"
  ],
  "action": {
    "default_popup": "popup/index.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
