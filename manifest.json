{
  "manifest_version": 3,
  "name": "PH Job Scraper",
  "version": "1.0.0",
  "description": "Scrape job listings from LinkedIn, Wellfound, BDJobs, and other platforms. Export to Excel or CSV.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["results.html", "assets/*", "chunks/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
